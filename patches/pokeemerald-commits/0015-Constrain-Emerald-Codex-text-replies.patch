From dbe2daa49492ca4eaba7fd695ef4db30ae4ea3cc Mon Sep 17 00:00:00 2001
From: hamishgrahambultitude <hamishgrahambultitude@gmail.com>
Date: Wed, 29 Apr 2026 12:55:31 +1000
Subject: [PATCH 15/20] Constrain Emerald Codex text replies

---
 .../emerald-host-bridge-server.mjs                |  2 +-
 .../codex-npc-bridge/mgba-emerald-host-bridge.lua | 15 +++++++++------
 2 files changed, 10 insertions(+), 7 deletions(-)

diff --git a/tools/codex-npc-bridge/emerald-host-bridge-server.mjs b/tools/codex-npc-bridge/emerald-host-bridge-server.mjs
index d851cc26d..09b7f8904 100644
--- a/tools/codex-npc-bridge/emerald-host-bridge-server.mjs
+++ b/tools/codex-npc-bridge/emerald-host-bridge-server.mjs
@@ -9,7 +9,7 @@ const scriptDir = dirname(fileURLToPath(import.meta.url));
 const host = process.env.EMERALD_CODEX_NPC_HOST ?? "127.0.0.1";
 const port = Number(process.env.EMERALD_CODEX_NPC_PORT ?? 8898);
 const mode = process.env.EMERALD_CODEX_NPC_MODE ?? "fake";
-const maxReplyChars = Number(process.env.EMERALD_CODEX_REPLY_MAX_CHARS ?? 220);
+const maxReplyChars = Number(process.env.EMERALD_CODEX_REPLY_MAX_CHARS ?? 52);
 const speciesByName = loadSpeciesMap();
 const demoShortcuts = new Map([
   ["1", "CHARIZARD"],
diff --git a/tools/codex-npc-bridge/mgba-emerald-host-bridge.lua b/tools/codex-npc-bridge/mgba-emerald-host-bridge.lua
index ea1be6f54..db663710a 100644
--- a/tools/codex-npc-bridge/mgba-emerald-host-bridge.lua
+++ b/tools/codex-npc-bridge/mgba-emerald-host-bridge.lua
@@ -23,6 +23,7 @@ local TOOL_ACTION_GIVE_POKEMON = 1
 local TOOL_FLAG_SHINY = 1
 local RESPONSE_LINE_MAX = 26
 local RESPONSE_LINES_PER_PAGE = 2
+local RESPONSE_TEXT_MAX = RESPONSE_LINE_MAX * RESPONSE_LINES_PER_PAGE
 
 local HOST = "127.0.0.1"
 local PORT = 8898
@@ -149,6 +150,9 @@ end
 
 local function encodeTextboxResponse(value, maxLen)
 	value = (value or ""):gsub("%s+", " "):match("^%s*(.-)%s*$")
+	if #value > RESPONSE_TEXT_MAX then
+		value = value:sub(1, RESPONSE_TEXT_MAX - 3):match("^%s*(.-)%s*$") .. "..."
+	end
 
 	local bytes = {}
 	local lineLen = 0
@@ -173,12 +177,10 @@ local function encodeTextboxResponse(value, maxLen)
 
 		if nextLen > RESPONSE_LINE_MAX then
 			if lineCount >= RESPONSE_LINES_PER_PAGE then
-				if not writeByte(bytes, 0xFB, maxLen) then break end
-				lineCount = 1
-			else
-				if not writeByte(bytes, 0xFE, maxLen) then break end
-				lineCount = lineCount + 1
+				break
 			end
+			if not writeByte(bytes, 0xFE, maxLen) then break end
+			lineCount = lineCount + 1
 			lineLen = 0
 			needsSpace = false
 		end
@@ -230,10 +232,11 @@ local function writeTool(toolJson)
 end
 
 local function publishReply(seq, reply, toolJson)
-	writeEmeraldResponse(MAILBOX_BASE + RESPONSE_OFFSET, RESPONSE_MAX, reply)
+	local byteCount = writeEmeraldResponse(MAILBOX_BASE + RESPONSE_OFFSET, RESPONSE_MAX, reply)
 	writeTool(toolJson)
 	write16(MAILBOX_BASE + ACK_OFFSET, seq)
 	emu:write8(MAILBOX_BASE + STATUS_OFFSET, STATUS_RESPONSE_READY)
+	console:log(string.format("Published Codex reply #%d (%d bytes)", seq, byteCount))
 end
 
 local function handleLine(line)
