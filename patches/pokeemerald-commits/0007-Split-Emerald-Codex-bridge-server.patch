index 000000000..6e8db4bdf
--- /dev/null
+++ b/tools/codex-npc-bridge/emerald-codex-app-server-client.mjs
@@ -0,0 +1,165 @@
+#!/usr/bin/env node
+import { spawn } from "node:child_process";
+import readline from "node:readline";
+
+const DEFAULT_TIMEOUT_MS = Number(process.env.EMERALD_CODEX_APP_SERVER_TIMEOUT_MS ?? 180000);
+
+class EmeraldCodexAppServerClient {
+  constructor() {
+    this.proc = spawn("codex", ["app-server"], {
+      stdio: ["pipe", "pipe", "inherit"],
+    });
+    this.nextId = 1;
+    this.pending = new Map();
+    this.threadId = null;
+    this.reply = "";
+    this.turnDone = null;
+
+    const rl = readline.createInterface({ input: this.proc.stdout });
+    rl.on("line", (line) => this.handleLine(line));
+    this.proc.on("exit", (code, signal) => {
+      const error = new Error(`codex app-server exited: code=${code} signal=${signal}`);
+      for (const { reject } of this.pending.values()) {
+        reject(error);
+      }
+      this.pending.clear();
+      if (this.turnDone) {
+        this.turnDone.reject(error);
+      }
+    });
+  }
+
+  send(method, params = {}, hasResponse = true) {
+    const message = { method, params };
+    let promise = Promise.resolve(null);
+
+    if (hasResponse) {
+      message.id = this.nextId++;
+      promise = new Promise((resolve, reject) => {
+        this.pending.set(message.id, { resolve, reject });
+      });
+    }
+
+    this.proc.stdin.write(`${JSON.stringify(message)}\n`);
+    return promise;
+  }
+
+  handleLine(line) {
+    let message;
+    try {
+      message = JSON.parse(line);
+    } catch {
+      return;
+    }
+
+    if (Object.hasOwn(message, "id")) {
+      const pending = this.pending.get(message.id);
+      if (!pending) {
+        return;
+      }
+      this.pending.delete(message.id);
+      if (message.error) {
+        pending.reject(new Error(message.error.message ?? JSON.stringify(message.error)));
+      } else {
+        pending.resolve(message.result);
+      }
+      return;
+    }
+
+    if (message.method === "item/agentMessage/delta") {
+      const delta = message.params?.delta ?? message.params?.text ?? "";
+      if (typeof delta === "string") {
+        this.reply += delta;
+      }
+      return;
+    }
+
+    if (message.method === "turn/completed" && this.turnDone) {
+      this.turnDone.resolve(message.params);
+      this.turnDone = null;
+    }
+  }
+
+  async initialize() {
+    await this.send("initialize", {
+      clientInfo: {
+        name: "emerald_codex_npc_bridge",
+        title: "Emerald Codex NPC Bridge",
+        version: "0.1.0",
+      },
+    });
+    await this.send("initialized", {}, false);
+  }
+
+  async startThread() {
+    const params = {};
+    const model = process.env.EMERALD_CODEX_MODEL ?? process.env.CODEX_MODEL;
+    if (model) {
+      params.model = model;
+    }
+    const result = await this.send("thread/start", params);
+    this.threadId = result?.thread?.id;
+    if (!this.threadId) {
+      throw new Error(`thread/start did not return a thread id: ${JSON.stringify(result)}`);
+    }
+  }
+
+  async ask(prompt) {
+    if (!this.threadId) {
+      await this.startThread();
+    }
+
+    this.reply = "";
+    const completed = new Promise((resolve, reject) => {
+      this.turnDone = { resolve, reject };
+    });
+
+    await this.send("turn/start", {
+      threadId: this.threadId,
+      input: [{ type: "text", text: prompt }],
+    });
+
+    await withTimeout(completed, DEFAULT_TIMEOUT_MS, "Timed out waiting for turn/completed");
+    return this.reply.trim();
+  }
+
+  close() {
+    this.proc.kill();
+  }
+}
+
+function withTimeout(promise, timeoutMs, message) {
+  let timer;
+  return Promise.race([
+    promise.finally(() => clearTimeout(timer)),
+    new Promise((_, reject) => {
+      timer = setTimeout(() => reject(new Error(message)), timeoutMs);
+    }),
+  ]);
+}
+
+async function main() {
+  const prompt = process.argv.slice(2).join(" ").trim();
+  if (!prompt) {
+    console.error("Usage: node emerald-codex-app-server-client.mjs <prompt>");
+    process.exit(2);
+  }
+
+  const client = new EmeraldCodexAppServerClient();
+  try {
+    await client.initialize();
+    const reply = await client.ask(prompt);
+    console.log(JSON.stringify({ reply }, null, 2));
+  } finally {
+    client.close();
+  }
+}
+
+if (import.meta.url === `file://${process.argv[1]}`) {
+  main().catch((error) => {
+    console.error(error.stack ?? error.message);
+    process.exit(1);
+  });
+}
+
+export { EmeraldCodexAppServerClient };
diff --git a/tools/codex-npc-bridge/emerald-host-bridge-server.mjs b/tools/codex-npc-bridge/emerald-host-bridge-server.mjs
new file mode 100644
index 000000000..849aabc54
--- /dev/null
+++ b/tools/codex-npc-bridge/emerald-host-bridge-server.mjs
@@ -0,0 +1,95 @@
+#!/usr/bin/env node
+import net from "node:net";
+import { EmeraldCodexAppServerClient } from "./emerald-codex-app-server-client.mjs";
+
+const host = process.env.EMERALD_CODEX_NPC_HOST ?? "127.0.0.1";
+const port = Number(process.env.EMERALD_CODEX_NPC_PORT ?? 8898);
+const mode = process.env.EMERALD_CODEX_NPC_MODE ?? "fake";
+
+let codexClient;
+
+function jsonLine(value) {
+  return `${JSON.stringify(value)}\n`;
+}
+
+async function getReply(prompt) {
+  if (mode === "fake") {
+    return `HELLO FROM HOST: ${prompt}`;
+  }
+
+  if (mode !== "codex") {
+    throw new Error(`Unsupported EMERALD_CODEX_NPC_MODE=${mode}`);
+  }
+
+  if (!codexClient) {
+    codexClient = new EmeraldCodexAppServerClient();
+    await codexClient.initialize();
+  }
+
+  return codexClient.ask(prompt);
+}
+
+async function handleRequest(socket, request) {
+  const seq = Number(request.seq ?? 0);
+  const prompt = String(request.prompt ?? "").trim();
+  const source = String(request.source ?? "emerald");
+
+  if (!prompt) {
+    socket.write(jsonLine({ seq, status: "error", error: "empty prompt" }));
+    return;
+  }
+
+  console.error(`[${source}] #${seq}: ${prompt}`);
+
+  try {
+    const reply = await getReply(prompt);
+    socket.write(jsonLine({ seq, status: "ok", reply }));
+    console.error(`[${source}] #${seq} reply: ${reply.slice(0, 120)}`);
+  } catch (error) {
+    const message = String(error?.message ?? error);
+    socket.write(jsonLine({ seq, status: "error", error: message }));
+    console.error(`[${source}] #${seq} error: ${message}`);
+  }
+}
+
+const server = net.createServer((socket) => {
+  socket.setEncoding("utf8");
+  let buffer = "";
+
+  socket.on("data", (chunk) => {
+    buffer += chunk;
+
+    while (true) {
+      const newline = buffer.indexOf("\n");
+      if (newline === -1) {
+        break;
+      }
+
+      const line = buffer.slice(0, newline).trim();
+      buffer = buffer.slice(newline + 1);
+
+      if (!line) {
+        continue;
+      }
+
+      let request;
+      try {
+        request = JSON.parse(line);
+      } catch {
+        socket.write(jsonLine({ seq: 0, status: "error", error: "invalid JSON" }));
+        continue;
+      }
+
+      void handleRequest(socket, request);
+    }
+  });
+});
+
+server.listen(port, host, () => {
+  console.error(`Emerald Codex NPC bridge listening on ${host}:${port} mode=${mode}`);
+});
+
+process.on("SIGINT", () => {
+  codexClient?.close();
+  server.close(() => process.exit(0));
+});
