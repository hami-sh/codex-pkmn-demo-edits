 async function getReply(prompt) {
+  const gift = parseGivePokemonCommand(prompt);
+  if (gift) {
+    return {
+      reply: `TOOL READY: SHINY LV.100 ${gift.displayName}.`,
+      tool: {
+        type: "give_pokemon",
+        species: gift.species,
+        level: 100,
+        shiny: true,
+      },
+    };
+  }
+
   if (mode === "fake") {
-    return `HELLO FROM HOST: ${prompt}`;
+    return {
+      reply: `HELLO FROM HOST: ${prompt}`,
+      tool: null,
+    };
   }
 
   if (mode !== "codex") {
@@ -26,7 +48,61 @@ async function getReply(prompt) {
     await codexClient.initialize();
   }
 
-  return codexClient.ask(prompt);
+  const reply = await codexClient.ask(
+    `Answer this as a concise Pokemon NPC. Use at most 2 short sentences: ${prompt}`,
+  );
+  return {
+    reply,
+    tool: null,
+  };
+}
+
+function loadSpeciesMap() {
+  const speciesPath = resolve(scriptDir, "../../include/constants/species.h");
+  const text = readFileSync(speciesPath, "utf8");
+  const map = new Map();
+
+  for (const match of text.matchAll(/^#define\s+SPECIES_([A-Z0-9_]+)\s+(\d+)/gm)) {
+    const rawName = match[1];
+    const species = Number(match[2]);
+    if (rawName === "NONE" || rawName === "EGG") {
+      continue;
+    }
+    const displayName = rawName.replace(/_/g, " ");
+    map.set(normalizePokemonName(rawName), { species, displayName });
+    map.set(normalizePokemonName(displayName), { species, displayName });
+  }
+
+  map.set("PIKA", map.get("PIKACHU"));
+  map.set("NIDORANF", map.get("NIDORAN F"));
+  map.set("NIDORANM", map.get("NIDORAN M"));
+  map.set("FARFETCHD", map.get("FARFETCHD"));
+  map.set("MRMIME", map.get("MR MIME"));
+  map.set("HOHO", map.get("HO OH"));
+
+  return map;
+}
+
+function normalizePokemonName(value) {
+  return String(value).toUpperCase().replace(/[^A-Z0-9]/g, "");
+}
+
+function parseGivePokemonCommand(prompt) {
+  const match = prompt.trim().match(/^GIVE(?:\s+ME)?\s+(.+)$/i);
+  if (!match) {
+    return null;
+  }
+
+  const name = normalizePokemonName(match[1]);
+  return speciesByName.get(name) ?? null;
+}
+
+function truncateReply(reply) {
+  if (reply.length <= maxReplyChars) {
+    return reply;
+  }
+
+  return `${reply.slice(0, Math.max(0, maxReplyChars - 3)).trimEnd()}...`;
 }
 
