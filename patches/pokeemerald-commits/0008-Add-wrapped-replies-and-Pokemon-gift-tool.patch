+    socket.write(jsonLine({ seq, status: "ok", reply, tool: result.tool ?? null }));
     console.error(`[${source}] #${seq} reply: ${reply.slice(0, 120)}`);
   } catch (error) {
     const message = String(error?.message ?? error);
diff --git a/tools/codex-npc-bridge/mgba-emerald-host-bridge.lua b/tools/codex-npc-bridge/mgba-emerald-host-bridge.lua
index 8aa3cae3a..3a09582db 100644
--- a/tools/codex-npc-bridge/mgba-emerald-host-bridge.lua
+++ b/tools/codex-npc-bridge/mgba-emerald-host-bridge.lua
@@ -14,6 +14,15 @@ local ACK_OFFSET = 6
 local STATUS_OFFSET = 8
 local RESPONSE_OFFSET = 42
 local RESPONSE_MAX = 256
+local TOOL_ACTION_OFFSET = RESPONSE_OFFSET + RESPONSE_MAX
+local TOOL_SPECIES_OFFSET = TOOL_ACTION_OFFSET + 1
+local TOOL_LEVEL_OFFSET = TOOL_SPECIES_OFFSET + 2
+local TOOL_FLAGS_OFFSET = TOOL_LEVEL_OFFSET + 1
+local TOOL_ACTION_NONE = 0
+local TOOL_ACTION_GIVE_POKEMON = 1
+local TOOL_FLAG_SHINY = 1
+local RESPONSE_LINE_MAX = 26
+local RESPONSE_LINES_PER_PAGE = 2
 
 local HOST = "127.0.0.1"
 local PORT = 8898
@@ -68,6 +77,10 @@ local function jsonNumber(line, key)
 	return tonumber(value)
 end
 
+local function jsonObject(line, key)
+	return line:match('"' .. key .. '"%s*:%s*(%b{})')
+end
+
 local function write16(address, value)
 	emu:write8(address, value & 0xFF)
 	emu:write8(address + 1, (value >> 8) & 0xFF)
@@ -98,20 +111,110 @@ local function emeraldByte(char)
 	return 0x00
 end
 
-local function writeEmeraldString(address, maxLen, value)
-	value = value or ""
-	local len = math.min(#value, maxLen - 1)
+local function writeByte(bytes, value, maxLen)
+	if #bytes >= maxLen - 1 then
+		return false
+	end
+
+	bytes[#bytes + 1] = value
+	return true
+end
+
+local function writeEncodedWord(bytes, word, maxLen)
+	for i = 1, #word do
+		if not writeByte(bytes, emeraldByte(word:sub(i, i)), maxLen) then
+			return false
+		end
+	end
+
+	return true
+end
+
+local function encodeTextboxResponse(value, maxLen)
+	value = (value or ""):gsub("%s+", " "):match("^%s*(.-)%s*$")
+
+	local bytes = {}
+	local lineLen = 0
+	local lineCount = 1
+
+	for word in value:gmatch("%S+") do
+		local remaining = word
+		while #remaining > RESPONSE_LINE_MAX do
+			local part = remaining:sub(1, RESPONSE_LINE_MAX)
+			remaining = remaining:sub(RESPONSE_LINE_MAX + 1)
+			if lineLen > 0 then
+				if not writeByte(bytes, 0xFE, maxLen) then break end
+				lineLen = 0
+				lineCount = lineCount + 1
+			end
+			if not writeEncodedWord(bytes, part, maxLen) then break end
+			lineLen = RESPONSE_LINE_MAX
+		end
+
+		local needsSpace = lineLen > 0
+		local nextLen = lineLen + (needsSpace and 1 or 0) + #remaining
+
+		if nextLen > RESPONSE_LINE_MAX then
+			if lineCount >= RESPONSE_LINES_PER_PAGE then
+				if not writeByte(bytes, 0xFB, maxLen) then break end
+				lineCount = 1
+			else
+				if not writeByte(bytes, 0xFE, maxLen) then break end
+				lineCount = lineCount + 1
+			end
+			lineLen = 0
+			needsSpace = false
+		end
+
+		if needsSpace then
+			if not writeByte(bytes, 0x00, maxLen) then break end
+			lineLen = lineLen + 1
+		end
+
+		if not writeEncodedWord(bytes, remaining, maxLen) then break end
+		lineLen = lineLen + #remaining
+	end
+
+	bytes[#bytes + 1] = 0xFF
+	return bytes
+end
+
+local function writeEmeraldResponse(address, maxLen, value)
+	local bytes = encodeTextboxResponse(value, maxLen)
+	for i, byte in ipairs(bytes) do
+		emu:write8(address + i - 1, byte)
+	end
+	return #bytes
+end
+
+local function writeTool(toolJson)
+	emu:write8(MAILBOX_BASE + TOOL_ACTION_OFFSET, TOOL_ACTION_NONE)
+	write16(MAILBOX_BASE + TOOL_SPECIES_OFFSET, 0)
+	emu:write8(MAILBOX_BASE + TOOL_LEVEL_OFFSET, 0)
+	emu:write8(MAILBOX_BASE + TOOL_FLAGS_OFFSET, 0)
+
+	if not toolJson then
+		return
+	end
 
-	for i = 1, len do
-		emu:write8(address + i - 1, emeraldByte(value:sub(i, i)))
+	local toolType = jsonString(toolJson, "type")
+	if toolType ~= "give_pokemon" then
+		return
 	end
 
-	emu:write8(address + len, 0xFF)
-	return len
+	local species = jsonNumber(toolJson, "species") or 0
+	local level = jsonNumber(toolJson, "level") or 100
+	local shiny = toolJson:match('"shiny"%s*:%s*true') ~= nil
+
+	write16(MAILBOX_BASE + TOOL_SPECIES_OFFSET, species)
+	emu:write8(MAILBOX_BASE + TOOL_LEVEL_OFFSET, math.max(1, math.min(100, level)))
+	emu:write8(MAILBOX_BASE + TOOL_FLAGS_OFFSET, shiny and TOOL_FLAG_SHINY or 0)
+	emu:write8(MAILBOX_BASE + TOOL_ACTION_OFFSET, TOOL_ACTION_GIVE_POKEMON)
 end
 
-local function publishReply(seq, reply)
-	writeEmeraldString(MAILBOX_BASE + RESPONSE_OFFSET, RESPONSE_MAX, reply)
+local function publishReply(seq, reply, toolJson)
+	writeEmeraldResponse(MAILBOX_BASE + RESPONSE_OFFSET, RESPONSE_MAX, reply)
+	writeTool(toolJson)
 	write16(MAILBOX_BASE + ACK_OFFSET, seq)
 	emu:write8(MAILBOX_BASE + STATUS_OFFSET, STATUS_RESPONSE_READY)
 end
@@ -120,13 +223,14 @@ local function handleLine(line)
 	local seq = jsonNumber(line, "seq") or 0
 	local status = jsonString(line, "status") or "unknown"
 	local reply = jsonString(line, "reply")
+	local toolJson = jsonObject(line, "tool")
