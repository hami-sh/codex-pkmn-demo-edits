 #define CODEX_RESPONSE_LENGTH 256
@@ -15,6 +19,20 @@ enum {
     CODEX_MAILBOX_STATUS_ERROR,
 };
 
+enum {
+    CODEX_TOOL_ACTION_NONE,
+    CODEX_TOOL_ACTION_GIVE_POKEMON,
+};
+
+#define CODEX_TOOL_FLAG_SHINY (1 << 0)
+
+enum {
+    CODEX_TOOL_RESULT_NONE,
+    CODEX_TOOL_RESULT_GIVEN_TO_PARTY,
+    CODEX_TOOL_RESULT_GIVEN_TO_PC,
+    CODEX_TOOL_RESULT_NO_ROOM,
+};
+
 struct CodexMailbox
 {
     u32 magic;
@@ -23,6 +41,11 @@ struct CodexMailbox
     u8 status;
     u8 command[CODEX_INPUT_LENGTH + 1];
     u8 response[CODEX_RESPONSE_LENGTH];
+    u8 toolAction;
+    u8 toolSpeciesLo;
+    u8 toolSpeciesHi;
+    u8 toolLevel;
+    u8 toolFlags;
 };
 
 static EWRAM_DATA u8 sCodexPromptBuffer[CODEX_INPUT_LENGTH + 1] = {0};
@@ -44,6 +67,11 @@ void PublishCodexPrompt(void)
     gCodexMailbox.status = CODEX_MAILBOX_STATUS_PENDING;
     StringCopyN(gCodexMailbox.command, sCodexPromptBuffer, CODEX_INPUT_LENGTH + 1);
     gCodexMailbox.response[0] = EOS;
+    gCodexMailbox.toolAction = CODEX_TOOL_ACTION_NONE;
+    gCodexMailbox.toolSpeciesLo = 0;
+    gCodexMailbox.toolSpeciesHi = 0;
+    gCodexMailbox.toolLevel = 0;
+    gCodexMailbox.toolFlags = 0;
 
     if (sCodexPromptBuffer[0] == EOS)
         gStringVar1[0] = EOS;
@@ -68,3 +96,46 @@ void BufferCodexResponse(void)
     else
         StringCopy(gStringVar1, gCodexMailbox.response);
 }
+
+void TryExecuteCodexTool(void)
+{
+    struct Pokemon mon;
+    u32 personality = 0;
+    u32 otId = 0;
+    u16 species = gCodexMailbox.toolSpeciesLo | (gCodexMailbox.toolSpeciesHi << 8);
+    u8 result;
+
+    if (gCodexMailbox.toolAction != CODEX_TOOL_ACTION_GIVE_POKEMON)
+    {
+        gSpecialVar_Result = CODEX_TOOL_RESULT_NONE;
+        return;
+    }
+
+    if (species == SPECIES_NONE || species >= NUM_SPECIES)
+    {
+        gSpecialVar_Result = CODEX_TOOL_RESULT_NONE;
+        return;
+    }
+
+    if (!(gCodexMailbox.toolFlags & CODEX_TOOL_FLAG_SHINY))
+    {
+        personality = 1;
+    }
+
+    if (gCodexMailbox.toolLevel < MIN_LEVEL)
+        gCodexMailbox.toolLevel = MIN_LEVEL;
+    if (gCodexMailbox.toolLevel > MAX_LEVEL)
+        gCodexMailbox.toolLevel = MAX_LEVEL;
+
+    CreateMon(&mon, species, gCodexMailbox.toolLevel, MAX_PER_STAT_IVS, TRUE, personality, OT_ID_PRESET, otId);
+    result = GiveMonToPlayer(&mon);
+    StringCopy(gStringVar2, gSpeciesNames[species]);
+    gCodexMailbox.toolAction = CODEX_TOOL_ACTION_NONE;
+
+    if (result == MON_GIVEN_TO_PARTY)
+        gSpecialVar_Result = CODEX_TOOL_RESULT_GIVEN_TO_PARTY;
+    else if (result == MON_GIVEN_TO_PC)
+        gSpecialVar_Result = CODEX_TOOL_RESULT_GIVEN_TO_PC;
+    else
+        gSpecialVar_Result = CODEX_TOOL_RESULT_NO_ROOM;
+}
